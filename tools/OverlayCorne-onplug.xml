<?xml version="1.0" encoding="UTF-8"?>
<!--
  Windows Task Scheduler task: start OverlayCorne when a device is plugged in
  (and at logon).  Import with:

    schtasks /Create /TN "OverlayCorne on plug" /XML tools\OverlayCorne-onplug.xml

  1. Adjust <Command> below to where OverlayCorne.exe lives.
  2. The event trigger fires on ANY device-configuration event (the Windows
     event XPath dialect cannot substring-match the device id); the
     IgnoreNew instance policy makes the extra fires harmless while the
     overlay is already running.  To narrow it to the W-CORNE only, replace
     the Select line's query with an exact match on your full
     DeviceInstanceId from Device Manager, e.g.
       *[System[(EventID=400)]] and
       *[EventData[Data[@Name='DeviceInstanceId']='USB\VID_55D4&amp;PID_0461\...']]
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Start OverlayCorne when the keyboard is plugged in.</Description>
  </RegistrationInfo>
  <Triggers>
    <EventTrigger>
      <Enabled>true</Enabled>
      <Subscription>&lt;QueryList&gt;&lt;Query Id="0" Path="Microsoft-Windows-Kernel-PnP/Configuration"&gt;&lt;Select Path="Microsoft-Windows-Kernel-PnP/Configuration"&gt;*[System[(EventID=400)]]&lt;/Select&gt;&lt;/Query&gt;&lt;/QueryList&gt;</Subscription>
    </EventTrigger>
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>false</AllowHardTerminate>
    <StartWhenAvailable>false</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>%LOCALAPPDATA%\OverlayCorne\OverlayCorne.exe</Command>
    </Exec>
  </Actions>
</Task>
